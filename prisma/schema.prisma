generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Door {
  id          Int        @id @default(autoincrement())
  name        String
  price       Int
  material    String
  size        String
  color       String
  image       String
  description String
  glass       String     @default("Без стекла")
  tearType    String     @default("Распашная")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  images      String[]
  favorites   Favorite[]
}

model Favorite {
  id     Int    @id @default(autoincrement())
  doorId Int
  userId String
  door   Door   @relation(fields: [doorId], references: [id], onDelete: Cascade)

  @@unique([doorId, userId])
}
